// ============================================================
// PIK — Persistent Identity Kernel
// Prisma Schema for PostgreSQL (Railway)
// Sprint 6A: FateAccount layer added above RootIdentity
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// FATE ACCOUNTS — Top-level credential layer
// One FateAccount → many Heroes (RootIdentity, max 2)
// Auth: email+password | google | apple
// ============================================================

model FateAccount {
  id           String    @id @default(uuid()) @map("account_id")
  email        String    @unique
  provider     String    @default("email")       // email | google | apple
  providerId   String?   @map("provider_id")     // OAuth subject ID (Google sub, Apple sub)
  passwordHash String?   @map("password_hash")   // null for OAuth-only accounts
  displayName  String?   @map("display_name")    // Optional account-level display name
  status       String    @default("active")       // active | suspended | deleted
  createdAt    DateTime  @default(now()) @map("created_at")
  lastLoginAt  DateTime? @map("last_login_at")
  // Sprint 15 — account-wide fate progression (shared across all heroes)
  fateXp       Int       @default(0) @map("fate_xp")
  fateLevel    Int       @default(1) @map("fate_level")

  heroes       RootIdentity[]
  sessions     AccountSession[]

  @@index([email])
  @@index([provider, providerId])
  @@map("fate_accounts")
}

model AccountSession {
  id              String    @id @default(uuid()) @map("session_id")
  accountId       String    @map("account_id")
  tokenHash       String    @unique @map("token_hash")     // SHA-256 of raw token
  selectedHeroId  String?   @map("selected_hero_id")       // null = at hero select, set after hero chosen
  expiresAt       DateTime  @map("expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  account         FateAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  hero            RootIdentity? @relation(fields: [selectedHeroId], references: [id], onDelete: SetNull)

  @@index([tokenHash])
  @@index([accountId])
  @@map("account_sessions")
}

// ============================================================
// IDENTITY KERNEL — Hero records (one per character slot)
// Now owned by a FateAccount. Max 2 per account enforced in service.
// ============================================================

model RootIdentity {
  id            String    @id @default(uuid()) @map("root_id")
  fateAccountId String?   @map("fate_account_id")   // FK to FateAccount (nullable for legacy)
  heroName      String    @unique @map("hero_name")
  fateAlignment String    @default("NONE") @map("fate_alignment")
  origin        String?
  fateXp        Int       @default(0) @map("fate_xp")
  fateLevel     Int       @default(1) @map("fate_level")
  // Sprint 15 — character-specific progression (per hero, not account-wide)
  heroXp        Int       @default(0) @map("hero_xp")
  heroLevel     Int       @default(1) @map("hero_level")
  enrolledBy    String    @default("self") @map("enrolled_by")
  enrolledAt    DateTime  @default(now()) @map("enrolled_at")
  status        String    @default("active")
  equippedTitle String?   @map("equipped_title")

  // Relations
  fateAccount   FateAccount?    @relation(fields: [fateAccountId], references: [id], onDelete: Cascade)
  activeSessions AccountSession[]
  personas      Persona[]
  keys          AuthKey[]
  sourceLinks   SourceLink[]
  events        IdentityEvent[]
  titles        UserTitle[]
  fateMarkers   FateMarker[]
  fateCaches    FateCache[]
  inventory     PlayerInventory[]
  equipment     PlayerEquipment[]
  challenges    WebAuthnChallenge[]
  sessions      PlayerSession[]
  wearables     IdentityToken[]
  quests        PlayerQuest[]
  dailyRites    DailyRite[]
  trainingEntries TrainingEntry[]
  pillarProgress  PillarProgress[]
  oaths           Oath[]
  nexus           PlayerNexus?
  components      PlayerComponents[]
  veilShards      VeilShard?
  tearEncounters  TearEncounter[]

  @@index([fateAccountId])
  @@map("root_identities")
}

model Persona {
  id            String    @id @default(uuid()) @map("persona_id")
  rootId        String    @map("root_id")
  displayName   String    @map("display_name")
  metadata      Json?
  status        String    @default("active")
  createdAt     DateTime  @default(now()) @map("created_at")

  root          RootIdentity @relation(fields: [rootId], references: [id], onDelete: Cascade)

  @@index([rootId])
  @@map("personas")
}

// ============================================================
// AUTHENTICATION — Legacy WebAuthn (retained, not used by Codex PWA)
// ============================================================

model AuthKey {
  id              String    @id @default(uuid()) @map("key_id")
  rootId          String    @map("root_id")
  credentialId    String    @unique @map("credential_id")
  publicKey       Bytes     @map("public_key")
  counter         BigInt    @default(0)
  deviceType      String?   @map("device_type")
  backedUp        Boolean   @default(false)
  transports      String[]  @default([])
  friendlyName    String?   @map("friendly_name")
  status          String    @default("active")
  createdAt       DateTime  @default(now()) @map("created_at")
  revokedAt       DateTime? @map("revoked_at")
  lastUsedAt      DateTime? @map("last_used_at")

  root            RootIdentity @relation(fields: [rootId], references: [id], onDelete: Cascade)

  @@index([rootId, status])
  @@map("auth_keys")
}

model WebAuthnChallenge {
  id          String    @id @default(uuid())
  rootId      String?   @map("root_id")
  challenge   String    @unique
  type        String
  metadata    Json?
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  root        RootIdentity? @relation(fields: [rootId], references: [id], onDelete: Cascade)

  @@index([challenge])
  @@index([expiresAt])
  @@map("webauthn_challenges")
}

// Legacy session tokens — kept for operator impersonation compatibility
model SessionToken {
  id          String    @id @default(uuid()) @map("token_id")
  rootId      String    @map("root_id")
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([tokenHash])
  @@index([expiresAt])
  @@map("session_tokens")
}

// ============================================================
// WEARABLE BRIDGE
// ============================================================

model IdentityToken {
  id          String    @id @default(uuid()) @map("token_id")
  rootId      String    @map("root_id")
  tokenType   String    @map("token_type")
  tokenUid    String    @unique @map("token_uid")
  friendlyName String?  @map("friendly_name")
  status      String    @default("active")
  issuedAt    DateTime  @default(now()) @map("issued_at")
  expiresAt   DateTime? @map("expires_at")
  lastTapAt   DateTime? @map("last_tap_at")
  tapCount    Int       @default(0) @map("tap_count")
  metadata    Json?

  root        RootIdentity @relation(fields: [rootId], references: [id], onDelete: Cascade)

  @@index([rootId])
  @@index([status])
  @@map("identity_tokens")
}

// ============================================================
// CONSENT — Sources and source links
// ============================================================

model Source {
  id          String    @id @map("source_id")
  name        String    @map("source_name")
  apiKeyHash  String    @map("api_key_hash")
  status      String    @default("active")
  sourceType  String    @default("venue") @map("source_type")
  createdAt   DateTime  @default(now()) @map("created_at")

  sourceLinks SourceLink[]
  fateCaches  FateCache[]

  @@map("sources")
}

model SourceLink {
  id          String    @id @default(uuid()) @map("link_id")
  rootId      String    @map("root_id")
  sourceId    String    @map("source_id")
  scope       String    @default("xp fate_markers titles")
  grantedBy   String    @map("granted_by")
  grantedAt   DateTime  @default(now()) @map("granted_at")
  revokedAt   DateTime? @map("revoked_at")
  revokedBy   String?   @map("revoked_by")
  status      String    @default("active")

  root        RootIdentity @relation(fields: [rootId], references: [id], onDelete: Cascade)
  source      Source       @relation(fields: [sourceId], references: [id])

  @@index([rootId, sourceId, status])
  @@map("source_links")
}

// ============================================================
// EVENT LEDGER — Append-only
// ============================================================

model IdentityEvent {
  id          String    @id @default(uuid()) @map("event_id")
  rootId      String    @map("root_id")
  eventType   String    @map("event_type")
  sourceId    String?   @map("source_id")
  payload     Json      @default("{}")
  changes     Json?     @map("changes_applied")
  createdAt   DateTime  @default(now()) @map("created_at")

  root        RootIdentity @relation(fields: [rootId], references: [id], onDelete: Cascade)

  @@index([rootId, createdAt])
  @@index([eventType])
  @@index([sourceId])
  @@map("identity_events")
}

// ============================================================
// PROGRESSION
// ============================================================

model Title {
  id            String    @id @map("title_id")
  displayName   String    @map("display_name")
  description   String?
  category      String?

  userTitles    UserTitle[]

  @@map("titles")
}

model UserTitle {
  id          String    @id @default(uuid())
  rootId      String    @map("root_id")
  titleId     String    @map("title_id")
  grantedAt   DateTime  @default(now()) @map("granted_at")
  sourceId    String?   @map("source_id")

  root        RootIdentity @relation(fields: [rootId], references: [id], onDelete: Cascade)
  title       Title        @relation(fields: [titleId], references: [id])

  @@unique([rootId, titleId])
  @@map("user_titles")
}

model FateMarker {
  id          String    @id @default(uuid())
  rootId      String    @map("root_id")
  marker      String
  sourceId    String?   @map("source_id")
  createdAt   DateTime  @default(now()) @map("created_at")

  root        RootIdentity @relation(fields: [rootId], references: [id], onDelete: Cascade)

  @@index([rootId])
  @@map("fate_markers")
}

// ============================================================
// LOOT SYSTEM
// ============================================================

model LootTable {
  id          String  @id @default(uuid()) @map("loot_table_id")
  cacheType   String  @map("cache_type")
  rewardType  String  @map("reward_type")
  rewardValue String  @map("reward_value")
  displayName String  @map("display_name")
  weight      Int     @default(100)
  rarityTier  String  @default("common") @map("rarity_tier")
  minLevel    Int     @default(1) @map("min_level")

  @@index([cacheType])
  @@map("loot_table")
}

model FateCache {
  id           String    @id @default(uuid()) @map("cache_id")
  rootId       String    @map("root_id")
  cacheType    String    @map("cache_type")
  rarity       String    @default("common")
  sourceId     String?   @map("source_id")
  trigger      String?
  status       String    @default("sealed")
  grantedAt    DateTime  @default(now()) @map("granted_at")
  openedAt     DateTime? @map("opened_at")
  rewardType   String?   @map("reward_type")
  rewardValue  String?   @map("reward_value")
  rewardName   String?   @map("reward_name")
  rewardRarity String?   @map("reward_rarity")

  root   RootIdentity @relation(fields: [rootId], references: [id], onDelete: Cascade)
  source Source?      @relation(fields: [sourceId], references: [id])

  @@index([rootId])
  @@index([rootId, status])
  @@map("fate_caches")
}

// ============================================================
// GEAR SYSTEM
// ============================================================

model GearItem {
  id          String  @id @map("item_id")
  name        String  @map("display_name")
  slot        String
  rarityTier  String  @default("common") @map("rarity_tier")
  description String?
  loreText    String? @map("lore_text")
  icon        String  @default("⚔")
  minLevel    Int     @default(1) @map("min_level")
  modifiers   Json    @default("{}")

  inventory   PlayerInventory[]

  @@index([slot])
  @@index([rarityTier])
  @@map("gear_items")
}

model PlayerInventory {
  id          String    @id @default(uuid()) @map("inventory_id")
  rootId      String    @map("root_id")
  itemId      String    @map("item_id")
  acquiredVia String    @default("cache") @map("acquired_via")
  acquiredAt  DateTime  @default(now()) @map("acquired_at")

  root        RootIdentity   @relation(fields: [rootId], references: [id], onDelete: Cascade)
  item        GearItem       @relation(fields: [itemId], references: [id])
  equipment   PlayerEquipment?

  @@index([rootId])
  @@map("player_inventory")
}

model PlayerEquipment {
  id          String    @id @default(uuid()) @map("equipment_id")
  rootId      String    @map("root_id")
  slot        String
  inventoryId String    @unique @map("inventory_id")
  equippedAt  DateTime  @default(now()) @map("equipped_at")

  root        RootIdentity    @relation(fields: [rootId], references: [id], onDelete: Cascade)
  inventory   PlayerInventory @relation(fields: [inventoryId], references: [id])

  @@unique([rootId, slot])
  @@map("player_equipment")
}

// ============================================================
// SESSIONS
// ============================================================

model PlayerSession {
  id            String    @id @default(uuid()) @map("session_id")
  rootId        String    @map("root_id")
  sourceId      String    @map("source_id")
  zone          String?
  status        String    @default("active")
  checkedInAt   DateTime  @default(now()) @map("checked_in_at")
  lastHeartbeat DateTime  @default(now()) @map("last_heartbeat")
  checkedOutAt  DateTime? @map("checked_out_at")
  durationSec   Int?      @map("duration_sec")
  summary       Json?

  root   RootIdentity @relation(fields: [rootId], references: [id], onDelete: Cascade)

  @@index([rootId])
  @@index([status])
  @@index([sourceId, status])
  @@index([checkedInAt])
  @@map("player_sessions")
}

// ============================================================
// QUESTS
// ============================================================

model QuestTemplate {
  id          String    @id @default(uuid()) @map("quest_id")
  name        String
  description String?
  questType   String    @map("quest_type")
  objectives  Json
  rewards     Json
  minLevel    Int       @default(1) @map("min_level")
  maxLevel    Int?      @map("max_level")
  sourceId    String?   @map("source_id")
  sortOrder   Int       @default(0) @map("sort_order")
  status      String    @default("active")
  createdAt   DateTime  @default(now()) @map("created_at")

  playerQuests PlayerQuest[]

  @@index([status])
  @@index([questType])
  @@map("quest_templates")
}

model PlayerQuest {
  id          String    @id @default(uuid()) @map("player_quest_id")
  rootId      String    @map("root_id")
  questId     String    @map("quest_id")
  status      String    @default("active")
  progress    Json      @default("[]")
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  root     RootIdentity  @relation(fields: [rootId], references: [id], onDelete: Cascade)
  quest    QuestTemplate @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@unique([rootId, questId])
  @@index([rootId, status])
  @@index([questId])
  @@map("player_quests")
}

// ============================================================
// CONFIG
// ============================================================

model Config {
  key         String    @id @map("config_key")
  value       String    @map("config_value")
  description String?
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("config")
}

// ============================================================
// TRAINING SYSTEM
// ============================================================
// Pool of rite templates drawn from when generating daily rites.
// Seeded once — operator can add more over time.
model RiteTemplate {
  id          String  @id @default(uuid()) @map("rite_template_id")
  pillar      String                        // forge | lore | veil
  title       String                        // "Complete 20 min of cardio"
  description String?                       // Flavour text
  loreText    String? @map("lore_text")     // In-world framing
  xpBase      Int     @default(50) @map("xp_base")
  difficulty  String  @default("standard")  // easy | standard | hard
  status      String  @default("active")    // active | retired

  dailyRites  DailyRite[]

  @@index([pillar, status])
  @@map("rite_templates")
}

// A hero's generated daily rites for a specific date.
// Created on first GET /api/training/daily/:rootId for that day.
model DailyRite {
  id           String    @id @default(uuid()) @map("daily_rite_id")
  rootId       String    @map("root_id")
  templateId   String    @map("template_id")
  dateKey      String    @map("date_key")      // "2026-03-08" UTC date string
  pillar       String                           // forge | lore | veil (denorm for query speed)
  status       String    @default("pending")   // pending | completed | skipped
  completedAt  DateTime? @map("completed_at")
  xpGranted    Int?      @map("xp_granted")    // Set on completion

  root         RootIdentity  @relation(fields: [rootId], references: [id], onDelete: Cascade)
  template     RiteTemplate  @relation(fields: [templateId], references: [id])

  @@unique([rootId, dateKey, pillar])           // One rite per pillar per day
  @@index([rootId, dateKey])
  @@map("daily_rites")
}

// Individual training log entries (the Chronicle).
model TrainingEntry {
  id           String    @id @default(uuid()) @map("entry_id")
  rootId       String    @map("root_id")
  pillar       String                           // forge | lore | veil
  activityType String    @map("activity_type")  // workout | cardio | sport | reading | writing | meditation | prayer | service | other
  durationMin  Int?      @map("duration_min")
  notes        String?
  xpGranted    Int       @default(0) @map("xp_granted")
  dailyRiteId  String?   @map("daily_rite_id")  // Linked rite if this was a rite completion
  createdAt    DateTime  @default(now()) @map("created_at")

  root         RootIdentity @relation(fields: [rootId], references: [id], onDelete: Cascade)

  @@index([rootId, createdAt])
  @@index([rootId, pillar])
  @@map("training_entries")
}

// Per-hero pillar XP tracking (separate from fate_xp).
model PillarProgress {
  id           String    @id @default(uuid()) @map("pillar_progress_id")
  rootId       String    @map("root_id")
  pillar       String                           // forge | lore | veil
  xp           Int       @default(0)
  level        Int       @default(1)
  streak       Int       @default(0)            // Current day streak
  longestStreak Int      @default(0) @map("longest_streak")
  lastActivityAt DateTime? @map("last_activity_at")

  root         RootIdentity @relation(fields: [rootId], references: [id], onDelete: Cascade)

  @@unique([rootId, pillar])
  @@index([rootId])
  @@map("pillar_progress")
}

// Weekly oath declarations.
model Oath {
  id           String    @id @default(uuid()) @map("oath_id")
  rootId       String    @map("root_id")
  pillar       String                           // forge | lore | veil
  declaration  String                           // Free text — what they commit to
  weekOf       String    @map("week_of")        // ISO week start "2026-03-04"
  status       String    @default("pending")   // pending | kept | broken
  resolvedAt   DateTime? @map("resolved_at")
  xpGranted    Int?      @map("xp_granted")

  root         RootIdentity @relation(fields: [rootId], references: [id], onDelete: Cascade)

  @@unique([rootId, weekOf])                    // One oath per hero per week
  @@index([rootId, status])
  @@map("oaths")
}

// ============================================================
// ECONOMY SYSTEM — Nexus currency + crafting components
// ============================================================
model PlayerNexus {
  id        String   @id @default(uuid()) @map("nexus_id")
  rootId    String   @unique @map("root_id")
  balance   Int      @default(0)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  root RootIdentity @relation(fields: [rootId], references: [id], onDelete: Cascade)

  @@index([rootId])
  @@map("player_nexus")
}

model PlayerComponents {
  id            String   @id @default(uuid()) @map("component_id")
  rootId        String   @map("root_id")
  componentType String   @map("component_type")
  quantity      Int      @default(0)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  root RootIdentity @relation(fields: [rootId], references: [id], onDelete: Cascade)

  @@unique([rootId, componentType])
  @@index([rootId])
  @@map("player_components")
}

// ============================================================
// VEIL TEARS — Sprint 13
// ──────────────────────────────────────────────

// Per-hero Veil Shard currency balance.
// One row per hero, upserted on each victory.
model VeilShard {
  id        String       @id @default(uuid()) @map("shard_id")
  rootId    String       @unique @map("root_id")
  balance   Int          @default(0)
  updatedAt DateTime     @default(now()) @updatedAt @map("updated_at")

  root RootIdentity @relation(fields: [rootId], references: [id], onDelete: Cascade)

  @@map("veil_shards")
}

// Individual battle record — one row per encounter outcome.
model TearEncounter {
  id        String    @id @default(uuid()) @map("encounter_id")
  rootId    String    @map("root_id")
  tearType  String    @map("tear_type")   // minor | wander | dormant | double
  tearName  String    @map("tear_name")
  outcome   String                        // won | fled
  shards    Int       @default(0)
  lat       Float?                        // GPS coords for future map features
  lon       Float?
  createdAt DateTime  @default(now()) @map("created_at")

  root RootIdentity @relation(fields: [rootId], references: [id], onDelete: Cascade)

  @@index([rootId, createdAt])
  @@index([rootId, outcome])
  @@map("tear_encounters")
}

// ============================================================
// PHASE 2 — Convergence Events
// ============================================================

// Active time-limited world events that boost rewards or alter spawns.
// Checked on every encounter — applied automatically by veil.service.
model ConvergenceEvent {
  id               String   @id @default(uuid()) @map("event_id")
  name             String
  description      String?
  flavorText       String?  @map("flavor_text")
  affectedTiers    String[] @map("affected_tiers")
  shardMultiplier  Float    @default(1.0) @map("shard_multiplier")
  cacheBonus       Boolean  @default(false) @map("cache_bonus")
  startsAt         DateTime @map("starts_at")
  endsAt           DateTime @map("ends_at")
  status           String   @default("active")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([status, endsAt])
  @@map("convergence_events")
}